<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.damemiorden.Promociones">

    <ImageView
        android:id="@+id/imgPromo"
        android:layout_width="300dp"
        android:layout_height="180dp"
        android:src="@drawable/promo_hamburguesa"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:padding="10dp"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tituloPromo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15% de descuento"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/imgPromo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"/>

    <ImageView
        android:id="@+id/img_promo2"
        android:layout_width="300dp"
        android:layout_height="180dp"
        android:src="@drawable/promo_campero"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:padding="10dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tituloPromo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tituloPromo2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25% de descuento"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/img_promo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp" />

    <ImageView
        android:id="@+id/imagePromo3"
        android:layout_width="300dp"
        android:layout_height="180dp"
        android:src="@drawable/images"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:padding="10dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tituloPromo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tituloPromo3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10% de descuento"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/imagePromo3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</ScrollView>